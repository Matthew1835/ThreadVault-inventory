<%- include('../partials/header') %>

<div class="breadcrumb">
    <a href="/">Categories</a> / <span><%= title %></span>
</div>

<section class="form-section">
    <h1><%= title %></h1>

    <% if (errors.length > 0) { %>
        <div class="error-box">
            <ul>
                <% errors.forEach(e => { %>
                    <li><%= e.msg %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="<%= action %>" method="POST" class="form-card">
        <div class="form-group">
            <label for="name">Category Name <span class="required">*</span></label>
            <input type="text" id="name" 
                name="name" value="<%= category.name || '' %>" 
                placeholder="e.g. Men's Clothing" required>
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" 
                rows="3" placeholder="Brief description of this category...">
                <%= category.description || '' %>
            </textarea>
        </div>

        <div class="form-group">
            <label for="image_url">Image URL</label>
            <input type="url" id="image_url" name="image_url" 
                value="<%= category.image_url || '' %>" placeholder="https://...">
            <small>Paste a direct image link (Unsplash, etc.)</small>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Save Category</button>
            <a href="/" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</section>

<%- include('../partials/footer') %>